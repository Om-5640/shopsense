# ────────────────────────────────────────────────────────────────
# ShopSense Environment Configuration
# Copy this file to .env and fill in your values.
# At minimum you need ONE LLM key + SERPER_API_KEY to run.
# ────────────────────────────────────────────────────────────────

# ── REQUIRED: Search ─────────────────────────────────────────────
# Used for: finding Reddit URLs via Google, real-time price lookup
# 2500 free searches/month at https://serper.dev
SERPER_API_KEY=

# ── REQUIRED: At least ONE LLM provider ──────────────────────────

# Gemini Flash 1.5 — free, 1500 req/day, 1M context window
# Best for: main analysis, rubric generation, embeddings
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq (llama-3.1-8b) — free, 14400 req/day, ultra-fast
# Best for: per-product scoring, category detection
# Get key: https://console.groq.com
GROQ_API_KEY=

# OpenRouter — free tier (llama-3.3-70b), master fallback
# System stays functional even if all other providers fail
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── RECOMMENDED ───────────────────────────────────────────────────

# Mistral (mistral-small) — free tier, natural conversational style
# Best for: interview question generation
# Get key: https://console.mistral.ai
MISTRAL_API_KEY=

# Cerebras (llama-3.1-8b) — free tier, separate quota from Groq
# Best for: parallel thread summarization (doubles effective rate limit)
# Get key: https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# ── OPTIONAL: Embeddings fallback chain ───────────────────────────
# System uses Gemini embeddings by default. These extend the fallback.

# Cohere embed-english-v3.0 — fallback #2 after Gemini
# Get key: https://dashboard.cohere.com
COHERE_API_KEY=

# HuggingFace Inference API — fallback #3
# Get key: https://huggingface.co/settings/tokens
HF_API_KEY=

# ── OPTIONAL: Deep Reddit (PRAW) ──────────────────────────────────
# Set USE_PRAW=true for 200-300+ comments per thread instead of ~50.
# Create a "script" app at: https://www.reddit.com/prefs/apps
USE_PRAW=false
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=shopsense-v1 by /u/your_reddit_username

# ── OPTIONAL: Monetization ────────────────────────────────────────
# Append your Amazon Associates tag to all generated Amazon links
AMAZON_AFFILIATE_TAG=

# ── OPTIONAL: Scoring mode ────────────────────────────────────────
# fast    — pure heuristic (instant, no LLM calls for scoring)
# hybrid  — LLM scores top 10 products, heuristic for the rest (default)
# llm     — full LLM scoring for every product (highest quality, slowest)
SCORING_MODE=hybrid

# ── DATABASE ──────────────────────────────────────────────────────
# Leave unset to use SQLite (zero-setup, data at web/prisma/shopping.db)
# Set to use PostgreSQL + pgvector for production multi-user deployment
# Run `docker-compose up -d` to start a local Postgres instance
# POSTGRES_URL=postgresql://shopping:shopping@localhost:5432/shopping_agent

# ── OPTIONAL: Production server ───────────────────────────────────
# Comma-separated list of allowed frontend origins for CORS
# Default: http://localhost:3000,http://127.0.0.1:3000
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# OpenRouter base URL — set automatically when OPENROUTER_API_KEY is present
OPENAI_BASE_URL=https://openrouter.ai/api/v1
